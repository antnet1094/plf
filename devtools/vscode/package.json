{
    "name": "vscode-plf",
    "displayName": "Prompt Language Format (PLF) - Syntax Highlighting",
    "description": "The official structured prompt language for LLMs. Stop hallucinations with explicit knowledge boundaries, behavioral fallbacks, and reasoning chains.",
    "version": "1.0.1",
    "publisher": "AntNetworks",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.60.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "plf",
                "aliases": [
                    "Prompt Language Format",
                    "plf"
                ],
                "extensions": [
                    ".plf"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "plf",
                "scopeName": "source.plf",
                "path": "./syntaxes/plf.tmLanguage.json"
            }
        ]
    }
}
