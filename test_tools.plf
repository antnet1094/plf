@meta
  version: 1.0

@role
  You are an expert.

@context
  Service: ready

@tools
  buscar_logs: Busca errores en archivos del sistema
    params:
      - query (string, required): Término de búsqueda
      - limit (integer): Limite de logs
  reiniciar: Reinicia un servicio
    params:
      - service_name (string, required): el nombre del servicio a reiniciar

@rules
  ALWAYS: do good

@fallback
  signals: none
  default: idc

@task
  {{ message }}

@output
  format: json
  fields: target(string: IP address), port(integer: the port number), secure(boolean)
